generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              String    @default("user")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  categories        Category[]
  assetRecords      AssetRecord[]
  liabilityRecords  LiabilityRecord[]
  refreshTokens     RefreshToken[]
  tags              Tag[]
  goals             Goal[]
  targetAllocation  TargetAllocation?

  @@map("users")
}

model Category {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  name        String        @db.VarChar(50)
  color       String        @db.VarChar(7)
  sortOrder   Int           @map("sort_order") @default(0)
  isActive    Boolean       @map("is_active") @default(true)
  isDefault   Boolean       @map("is_default") @default(false)
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetItems  AssetItem[]
  goals       Goal[]

  @@index([userId, deletedAt])
  @@unique([userId, name, deletedAt])
  @@map("categories")
}

model AssetItem {
  id            String      @id @default(uuid())
  assetRecordId String      @map("asset_record_id")
  categoryId    String      @map("category_id")
  amount        Decimal     @db.Decimal(15, 2)
  createdAt     DateTime    @default(now()) @map("created_at")

  assetRecord   AssetRecord @relation(fields: [assetRecordId], references: [id], onDelete: Cascade)
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([assetRecordId])
  @@index([categoryId])
  @@unique([assetRecordId, categoryId])
  @@map("asset_items")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AssetRecord {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  date              DateTime          @db.Date
  cash              Decimal           @db.Decimal(15, 2)
  longTermInvest    Decimal           @map("long_term_invest") @db.Decimal(15, 2)
  stableBond        Decimal           @map("stable_bond") @db.Decimal(15, 2)
  total             Decimal           @db.Decimal(15, 2)
  note              String?           @db.VarChar(100)
  editCount         Int               @default(0) @map("edit_count")
  previousSnapshot  Json?             @map("previous_snapshot")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetItems        AssetItem[]
  tagLinks          AssetRecordTag[]

  @@index([userId])
  @@map("asset_records")
}

model Tag {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  name      String            @db.VarChar(30)
  color     String            @db.VarChar(7)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagLinks  AssetRecordTag[]

  @@index([userId])
  @@unique([userId, name])
  @@map("tags")
}

model AssetRecordTag {
  id            String      @id @default(uuid())
  assetRecordId String      @map("asset_record_id")
  tagId         String      @map("tag_id")
  createdAt     DateTime    @default(now()) @map("created_at")

  assetRecord   AssetRecord @relation(fields: [assetRecordId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([assetRecordId])
  @@index([tagId])
  @@unique([assetRecordId, tagId])
  @@map("asset_record_tags")
}

model Goal {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  name            String     @db.VarChar(50)
  targetAmount    Decimal    @map("target_amount") @db.Decimal(15, 2)
  targetDate      DateTime   @map("target_date") @db.Date
  scope           String     @default("total") @db.VarChar(10)
  categoryId      String?    @map("category_id")
  isCompleted     Boolean    @default(false) @map("is_completed")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, scope])
  @@map("goals")
}

model LiabilityRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String   @db.VarChar(100)
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @db.Date
  note        String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("liability_records")
}

model TargetAllocation {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  allocations      Json     @map("allocations")
  warningThreshold Decimal  @default(10) @map("warning_threshold") @db.Decimal(5, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("target_allocations")
}
